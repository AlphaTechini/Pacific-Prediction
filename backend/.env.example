APP_ENV=development
APP_ADDR=:8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/prediction?sslmode=disable
MIGRATIONS_DIR=./migrations
AUTH_SESSION_TTL=168h
AUTH_COOKIE_NAME=pacific_prediction_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
PLAYER_STARTING_BALANCE=1000.00
PACIFICA_REST_BASE_URL=https://api.testnet.pacifica.fi
PACIFICA_MARKET_INFO_CACHE_TTL=24h
PACIFICA_MARKET_INFO_HTTP_TIMEOUT=10s
