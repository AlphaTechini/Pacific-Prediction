APP_ENV=development
APP_ADDR=:8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/prediction?sslmode=disable
DB_MIN_CONNS=1
DB_MIN_IDLE_CONNS=1
DB_MAX_CONNS=4
DB_MAX_CONN_LIFETIME=24h
DB_MAX_CONN_IDLE_TIME=2h
DB_HEALTH_CHECK_PERIOD=30s
DB_CONNECT_TIMEOUT=15s
MIGRATIONS_DIR=./migrations
AUTH_SESSION_TTL=168h
AUTH_COOKIE_NAME=pacific_prediction_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
PLAYER_STARTING_BALANCE=1000.00
MARKET_PRICE_THRESHOLD_CREATION_BAND_PERCENT=2.00
PACIFICA_REST_BASE_URL=https://api.testnet.pacifica.fi
PACIFICA_MARKET_INFO_CACHE_TTL=24h
PACIFICA_MARKET_INFO_HTTP_TIMEOUT=10s
REALTIME_HEARTBEAT_INTERVAL=15s
SETTLEMENT_SCAN_INTERVAL=15s
SETTLEMENT_SCAN_BATCH_SIZE=50
SETTLEMENT_PRICE_LOOKAHEAD=2m
SETTLEMENT_PRICE_RETRY_INTERVAL=500ms
